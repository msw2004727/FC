{
  "name": "fc-football-functions",
  "description": "Cloud Functions for FC Football — LINE push notifications",
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "scripts": {
    "backfill:attendance-stats": "node backfill-user-attendance-stats.js",
    "test:rules:unit": "jest --runInBand tests/firestore.rules.test.js",
    "test:rules": "firebase emulators:exec --config ../firebase.json --only firestore --project demo-rules-test \"npm run test:rules:unit\""
  },
  "dependencies": {
    "@google-cloud/bigquery": "^8.1.1",
    "@google-cloud/translate": "^9.3.0",
    "@line/bot-sdk": "^10.8.0",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "google-auth-library": "^9.15.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.3",
    "firebase": "^10.14.1",
    "jest": "^29.7.0"
  }
}

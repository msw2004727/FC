# Static assets (versioned with ?v=)
/css/*
  Cache-Control: public, max-age=31536000, immutable
  Cloudflare-CDN-Cache-Control: no-store

/js/*
  Cache-Control: public, max-age=31536000, immutable
  Cloudflare-CDN-Cache-Control: no-store

/pages/*
  Cache-Control: public, max-age=31536000, immutable
  Cloudflare-CDN-Cache-Control: no-store

/images/*
  Cache-Control: public, max-age=86400

/assets/og/*
  Cache-Control: public, max-age=86400

# HTML entry points
/index.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

/activities
  Cache-Control: public, max-age=0, must-revalidate


/profile
  Cache-Control: public, max-age=0, must-revalidate

/ops-report
  Cache-Control: public, max-age=0, must-revalidate
  X-Robots-Tag: noindex, nofollow, noarchive

/ops-report.html
  Cache-Control: public, max-age=0, must-revalidate
  X-Robots-Tag: noindex, nofollow, noarchive

/events/*
  Cache-Control: public, max-age=0, must-revalidate

/teams/*
  Cache-Control: public, max-age=0, must-revalidate

/tournaments/*
  Cache-Control: public, max-age=0, must-revalidate

/game-lab.html
  Cache-Control: public, max-age=0, must-revalidate

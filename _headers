# Static assets (versioned with ?v=)
/css/*
  Cache-Control: public, max-age=31536000, immutable

/js/*
  Cache-Control: public, max-age=31536000, immutable

/pages/*
  Cache-Control: public, max-age=31536000, immutable

/images/*
  Cache-Control: public, max-age=86400

# HTML entry points
/index.html
  Cache-Control: public, max-age=0, must-revalidate

/
  Cache-Control: public, max-age=0, must-revalidate

/game-lab.html
  Cache-Control: public, max-age=0, must-revalidate
  X-Robots-Tag: noindex, nofollow, noarchive

/changelog/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Robots-Tag: noindex, nofollow, noarchive

/valuation/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Robots-Tag: noindex, nofollow, noarchive

# SEO landing pages
/seo/*
  Cache-Control: public, max-age=86400

# Privacy & Terms
/privacy.html
  Cache-Control: public, max-age=86400
/terms.html
  Cache-Control: public, max-age=86400

# Docs (內部報告類,強制每次 revalidate 確保看到最新)
/docs/*
  Cache-Control: public, max-age=0, must-revalidate
  X-Robots-Tag: noindex, nofollow

# Service Worker
/sw.js
  Cache-Control: public, max-age=0, must-revalidate

{
  "name": "fc-github-rules-tests",
  "private": true,
  "scripts": {
    "test:rules:unit": "jest --runInBand --runTestsByPath tests/firestore.rules.test.js tests/firestore-rules-extended.test.js tests/team-split-rules.test.js tests/firestore-rules/team-feed-rules.test.js tests/firestore-rules/tournament-member-rules.test.js",
    "test:rules": "cross-env CI=true NO_UPDATE_NOTIFIER=1 FIREBASE_SKIP_UPDATE_CHECK=true XDG_CONFIG_HOME=.firebase-config firebase emulators:exec --only firestore --project demo-rules-test \"npm run test:rules:unit\"",
    "test:rules:watch": "cross-env CI=true NO_UPDATE_NOTIFIER=1 FIREBASE_SKIP_UPDATE_CHECK=true XDG_CONFIG_HOME=.firebase-config firebase emulators:exec --only firestore --project demo-rules-test \"npm run test:rules:unit -- --watch\"",
    "test:unit": "jest tests/unit/",
    "test:unit:coverage": "jest tests/unit/ --coverage",
    "test:e2e": "npx playwright test tests/e2e/",
    "test": "jest tests/unit/"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^3.0.3",
    "@playwright/test": "^1.58.2",
    "cross-env": "^7.0.3",
    "firebase": "^10.14.1",
    "firebase-tools": "^14.8.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": [
      "/node_modules/",
      "<rootDir>/.claude/"
    ],
    "collectCoverageFrom": [
      "js/**/*.js",
      "!js/firebase-config.js",
      "!js/three.min.js"
    ],
    "coverageDirectory": "coverage"
  }
}
